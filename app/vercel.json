{
  "version": 2,
  "name": "snacktrack-app",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!assets/|sw\\.js|manifest\\.json|icon-|favicon|robots\\.txt|.*\\.png|.*\\.ico|.*\\.svg|.*\\.webp|.*\\.css|.*\\.js).*)",
      "destination": "/index.html"
    }
  ]
}
